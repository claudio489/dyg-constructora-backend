# ============================================
# D&G CONSTRUCTORA - Environment Variables
# ============================================

# --- Kimi OAuth (required for auth) ---
APP_ID=your-app-id
APP_SECRET=your-app-secret
VITE_APP_ID=your-app-id
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com
OWNER_UNION_ID=your-owner-union-id

# --- Database (MySQL) ---
DATABASE_URL=mysql://user:pass@host:port/database

# --- Mercado Público Chile ---
MP_TICKET=your-mp-ticket-here

# --- Frontend API URL (only needed when frontend is separate) ---
# Set this in Netlify: VITE_API_URL=https://your-render-app.onrender.com/api/trpc
# Leave empty for bundled deploy (localhost development)
VITE_API_URL=
